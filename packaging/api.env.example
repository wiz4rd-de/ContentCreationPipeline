# SEO Content Pipeline – API configuration template
#
# Rename this file to `api.env` and fill in the values below.
# The Settings page in the Streamlit app does this for you, but you can
# also edit this file directly.
#
# Syntax: KEY=VALUE (no spaces around `=`, no surrounding quotes needed).
# Leave a key blank if you do not use it. Required keys must be non-empty
# for the pipeline to run.

# ── LLM provider (required) ─────────────────────────────────────────
# Provider: one of `anthropic`, `openai`, `google`, `openai_compat`.
LLM_PROVIDER=
# Model identifier. Examples:
#   anthropic      → claude-sonnet-4-20250514
#   openai         → gpt-4o
#   google         → gemini-2.5-flash
#   openai_compat  → any model name the backend accepts
LLM_MODEL=
# API key for the selected provider. Not needed for local providers
# such as Ollama running on `LLM_API_BASE`.
LLM_API_KEY=

# ── LLM provider (optional tuning) ──────────────────────────────────
# Base URL override. Required for `openai_compat` (e.g. Ollama, LM Studio).
LLM_API_BASE=
# Sampling temperature. Default: 0.3
LLM_TEMPERATURE=
# Maximum tokens in the response. Default: 8192
LLM_MAX_TOKENS=

# ── DataForSEO (required for keyword research + SERP) ───────────────
# Base64-encoded `login:password`. Generate with:
#   echo -n 'login:password' | base64
DATAFORSEO_AUTH=
# API base URL. Use https://api.dataforseo.com/v3
DATAFORSEO_BASE=
