# SEO Pipeline – API Configuration
# Copy to api.env and fill in your credentials:
#   cp seo-pipeline/api.env.example seo-pipeline/api.env
#
# Supported providers (uncomment ONE block):

# ── DataForSEO ──────────────────────────────────────
# SEO_PROVIDER=dataforseo
# DATAFORSEO_LOGIN=your_login
# DATAFORSEO_PASSWORD=your_password
# DATAFORSEO_BASE=https://api.dataforseo.com/v3

# ── SEMrush ─────────────────────────────────────────
# SEO_PROVIDER=semrush
# SEMRUSH_API_KEY=your_api_key
# SEMRUSH_BASE=https://api.semrush.com

# ── Ahrefs ──────────────────────────────────────────
# SEO_PROVIDER=ahrefs
# AHREFS_API_KEY=your_api_key
# AHREFS_BASE=https://api.ahrefs.com/v3

# ── Generic REST (any keyword API) ──────────────────
SEO_PROVIDER=generic
GENERIC_API_KEY=your_api_key
GENERIC_KEYWORDS_URL=https://your-seo-api.example.com/keywords
GENERIC_SERP_URL=https://your-seo-api.example.com/serp
GENERIC_COMPETITORS_URL=https://your-seo-api.example.com/competitors

# ── Common settings ─────────────────────────────────
SEO_MARKET=us
SEO_LANGUAGE=en
